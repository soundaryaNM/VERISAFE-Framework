*.py[cod]
*.pyo
*.pyd
*.pyc
pip-wheel-metadata/
*.egg-info/

# Virtual environments
.venv/
venv/
ENV/
env/

# IDEs and editors
.vscode/
.idea/
*.sublime-* 

# OS files
.DS_Store
Thumbs.db

