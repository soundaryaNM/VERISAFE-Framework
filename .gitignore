.pytest_cache/

# Distribution / packaging
dist/
build/
eggs/
*.egg
*.whl

# Logs and temporary files
*.log
work/
tmp/
*.tmp

# Secrets / keys
*.pem
*.key

# Other generated files
*.pyc
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
